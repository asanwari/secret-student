APP_SECRET=change-me-for-shared-deployments
DATABASE_URL=sqlite:///./data/secret_student.sqlite3
# mock | external | embedded_llamacpp
LLM_RUNTIME=mock
# Kept for backwards compatibility. LLM_RUNTIME takes precedence.
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=openbmb/MiniCPM-V-4.6
LLM_ENABLE_THINKING=false
LLAMA_CPP_SERVER_BIN=/app/llama-server
LLAMA_CPP_MODEL_REF=ggml-org/NVIDIA-Nemotron-3-Nano-Omni:Q4_K_M
LLAMA_CPP_HOST=127.0.0.1
LLAMA_CPP_PORT=8001
LLAMA_CPP_API_KEY=local-dev-key
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_GPU_LAYERS=999
LLAMA_CPP_THREADS=8
LLAMA_CPP_PARALLEL=1
LLAMA_CPP_STARTUP_TIMEOUT=900
LLAMA_CPP_EXTRA_ARGS=
TRACE_DESTINATION=local
TRACE_DIR=debug_traces
TRACE_HUB_REPO_ID=
TRACE_HUB_TOKEN=
TRACE_HUB_PRIVATE=true
TRACE_HUB_INCLUDE_CONTENT=false
QUIZ_QUESTION_COUNT=5
BOSS_QUESTION_COUNT=10
BOSS_MAX_MISTAKES=3
CORS_ORIGINS=http://127.0.0.1:7860,http://localhost:7860
